<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<SharedFlowBundle revision="1" name="sf-mcp-session-delete">
    <DisplayName>sf-mcp-session-delete</DisplayName>
    <Description>Shared Flow for MCP Session Deletion</Description>
    <SharedFlows>
        <SharedFlow>default</SharedFlow>
    </SharedFlows>
    <Policies>
        <Policy>MCP-LookupTargetSessions</Policy>
        <Policy>MCP-PrepareDeleteFanout</Policy>
        <Policy>MCP-DeleteTargetSessions-Fanout</Policy>
        <Policy>MCP-DeleteSession</Policy>
        <Policy>MCP-DeleteSessionTools</Policy>
        <Policy>MCP-DeleteTargetSession</Policy>
        <Policy>MCP-DeleteTargetSessions</Policy>
        <Policy>MCP-DeleteSessionResponse</Policy>
    </Policies>
    <Resources>
        <Resource>java://service-fanout.jar</Resource>
        <Resource>jsc://mcp-prep-sessions-delete.js</Resource>
    </Resources>
</SharedFlowBundle>
