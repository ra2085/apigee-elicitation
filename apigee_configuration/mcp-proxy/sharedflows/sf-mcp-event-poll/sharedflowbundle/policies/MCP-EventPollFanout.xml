<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<JavaCallout async="false" continueOnError="true" enabled="true" name="MCP-EventPollFanout">
  <DisplayName>MCP-EventPollFanout</DisplayName>
  <Properties>
    <Property name="urls">{mcp_target_urls}</Property>
    <Property name="method">GET</Property>
    <Property name="headers">Accept:text/event-stream|mcp-session-id:{mcp_target_session_id_{servicefanout_current_index}}</Property>
    <!-- We set a short timeout for transient SSE polling -->
    <Property name="timeout-seconds">2</Property>
    <Property name="continue-on-error">true</Property>
    <Property name="output-variable-prefix">fanout_event_poll</Property>
  </Properties>
  <ClassName>com.google.apigee.callouts.ServiceFanout</ClassName>
  <ResourceURL>java://service-fanout.jar</ResourceURL>
</JavaCallout>
