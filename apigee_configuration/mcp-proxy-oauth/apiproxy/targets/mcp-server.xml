<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<TargetEndpoint name="mcp-server">
  <Description/>
  <FaultRules/>
  <PreFlow name="PreFlow">
    <Request>
      <Step>
        <Condition>mcp_target_url != null</Condition>
        <Name>MCP-SetTargetUrl</Name>
      </Step>
      <Step>
        <Condition>mcp_target_url != null</Condition>
        <Name>MCP-ExtractTargetSessionId</Name>
      </Step>
      <Step>
        <Condition>(mcp_target_url != null) and (mcp_target_session_id != null)</Condition>
        <Name>MCP-SetTargetSessionHeader</Name>
      </Step>
    </Request>
    <Response/>
  </PreFlow>
  <PostFlow name="PostFlow">
    <Request/>
    <Response/>
  </PostFlow>
  <Flows/>
  <EventFlow name="EventFlow" content-type="text/event-stream">
    <Response>
      <Step>
        <Name>MCP-CollectEvents</Name>
      </Step>
    </Response>
  </EventFlow>
  <HTTPTargetConnection>
    <!--<URL>{mcp_tool_target}</URL>-->
    <URL>http://{mcp_target_host}/{mcp_target_path}</URL>
  </HTTPTargetConnection>
</TargetEndpoint>
