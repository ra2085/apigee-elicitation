<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<SharedFlowBundle revision="1" name="sf-mcp-tool-list">
    <DisplayName>sf-mcp-tool-list</DisplayName>
    <Description>Shared Flow for MCP Tool List Request Fanout</Description>
    <SharedFlows>
        <SharedFlow>default</SharedFlow>
    </SharedFlows>
    <Policies>
        <Policy>MCP-LookupSessionTools</Policy>
        <Policy>MCP-PrepareInitializeRequestFanout</Policy>
        <Policy>MCP-InitializeRequestFanout</Policy>
        <Policy>MCP-PrepareInitializedFanout</Policy>
        <Policy>MCP-InitializedRequestFanout</Policy>
        <Policy>MCP-ToolListRequestFanout</Policy>
    </Policies>
    <Resources>
        <Resource>java://service-fanout.jar</Resource>
        <Resource>jsc://mcp-prep-initialized.js</Resource>
    </Resources>
</SharedFlowBundle>
