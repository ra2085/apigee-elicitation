<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<JavaCallout async="false" continueOnError="true" enabled="true" name="MCP-DeleteTargetSessions-Fanout">
  <DisplayName>MCP-DeleteTargetSessions-Fanout</DisplayName>
  <Properties>
    <!-- Assumes a preceding JS policy has populated these variables from cache -->
    <Property name="urls">{mcp_target_urls}</Property>
    <Property name="method">DELETE</Property>
    <Property name="headers">Content-Type:application/json|Accept:application/json|mcp-session-id:{mcp_target_session_id_{servicefanout_current_index}}</Property>
    <Property name="connect-timeout-seconds">5</Property>
    <!-- It's best to continue even if one deletion fails -->
    <Property name="continue-on-error">true</Property>
    <Property name="output-variable-prefix">fanout_delete</Property>
  </Properties>
  <ClassName>com.google.apigee.callouts.ServiceFanout</ClassName>
  <ResourceURL>java://service-fanout.jar</ResourceURL>
</JavaCallout>
