<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<SharedFlowBundle revision="1" name="sf-mcp-event-poll">
    <DisplayName>sf-mcp-event-poll</DisplayName>
    <Description>Shared Flow for Polling and Aggregating Elicitation Events across MCP servers</Description>
    <SharedFlows>
        <SharedFlow>default</SharedFlow>
    </SharedFlows>
    <Policies>
        <Policy>MCP-PrepareEventPollFanout</Policy>
        <Policy>MCP-EventPollFanout</Policy>
        <Policy>MCP-AggregateEvents</Policy>
    </Policies>
    <Resources>
        <Resource>java://service-fanout.jar</Resource>
        <Resource>jsc://mcp-aggregate-events.js</Resource>
    </Resources>
</SharedFlowBundle>
