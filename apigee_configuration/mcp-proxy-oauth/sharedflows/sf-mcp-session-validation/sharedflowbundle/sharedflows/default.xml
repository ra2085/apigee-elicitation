<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<SharedFlow name="default">
    <Step>
        <Name>MCP-VerifySessionToken</Name>
    </Step>
    <Step>
        <Condition>oauthv2.MCP-VerifySessionToken.failed = "true"</Condition>
        <Name>MCP-InvalidSession</Name>
    </Step>
    <Step>
        <Condition>oauthv2.MCP-VerifySessionToken.failed = "false"</Condition>
        <Name>MCP-ExtractSessionAttributes</Name>
    </Step>
</SharedFlow>
